{
  "name": "codex-loop",
  "version": "1.0.0",
  "description": "跨平台 Codex 恢复与完成审查循环 CLI",
  "type": "module",
  "bin": {
    "codex-loop": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "codex",
    "cli",
    "automation",
    "supervisor"
  ],
  "license": "MIT",
  "dependencies": {
    "execa": "9.6.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.1"
  }
}
